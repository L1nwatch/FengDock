{
    {$CADDY_GLOBAL_OPTIONS}
    admin off
}

{$DOMAIN} {
    encode gzip zstd

    @triggertodo_api path /api/health /api/todo/* /api/triggers /api/triggers/* /api/events /api/events/* /api/epics /api/epics/* /api/sync/* /api/jira/*
    handle @triggertodo_api {
        reverse_proxy backend:8001
    }

    @triggertodo_frontend path /static/todo /static/todo/*
    handle @triggertodo_frontend {
        uri strip_prefix /static/todo
        reverse_proxy backend:8001
    }

    @triggertodo_assets path /assets/*
    handle @triggertodo_assets {
        reverse_proxy backend:8001
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /static/* {
        reverse_proxy backend:8000
    }

    @loblaws path /loblaws/*
    handle @loblaws {
        reverse_proxy backend:8000
    }

    @board path "/board" "/board/manage"
    handle @board {
        reverse_proxy backend:8000
    }

    @board_slash path "/board/" "/board/manage/"
    handle @board_slash {
        reverse_proxy backend:8000
    }

    handle {
        root * /srv/www
        @json_viewer path "/tools/json-viewer"
        redir @json_viewer /tools/json-viewer.html 302
        @json_viewer_slash path "/tools/json-viewer/"
        redir @json_viewer_slash /tools/json-viewer.html 302
        try_files {path} /index.html
        file_server
    }

    @healthz path "/proxy-health"
    respond @healthz 200

    log {
        output stdout
        format console
    }
}
